{
"openapi": "3.0.0",
"info": {
"title": "TekIt Admin API",
"description": "API documentation for the TekIt Admin Panel backend.",
"version": "1.0.0"
},
"servers": [
{
"url": "http://52.86.158.16/api",
"description": "Production server"
}
],
"components": {
"securitySchemes": {
"bearerAuth": {
"type": "http",
"scheme": "bearer",
"bearerFormat": "JWT"
}
},
"schemas": {
"LoginRequest": {
"type": "object",
"required": ["email", "password"],
"properties": {
"email": { "type": "string", "example": "[admin@tekit.com](mailto:admin@tekit.com)" },
"password": { "type": "string", "example": "Admin@12345" }
}
},
"CategoryRequest": {
"type": "object",
"required": ["name"],
"properties": {
"name": { "type": "string", "example": "Technology" },
"description": { "type": "string", "example": "Tech articles" }
}
},
"BlogRequest": {
"type": "object",
"required": ["title", "author", "date", "content"],
"properties": {
"title": { "type": "string", "example": "New Blog Post" },
"category_id": { "type": "integer", "example": 1 },
"author": { "type": "string", "example": "John Doe" },
"date": { "type": "string", "format": "date", "example": "2024-01-20" },
"featured_image_url": { "type": "string", "example": "https://example.com/img.jpg" },
"summary": { "type": "string", "example": "Short summary." },
"content": { "type": "string", "example": "<p>Content</p>" },
"status": { "type": "string", "enum": ["draft", "published", "archived"], "example": "published" }
}
},
"JobRequest": {
"type": "object",
"required": ["title", "description"],
"properties": {
"title": { "type": "string", "example": "Senior Node.js Developer" },
"experience": { "type": "string", "example": "3-5 years" },
"location": { "type": "string", "example": "Remote" },
"notice_period": { "type": "string", "example": "30 days" },
"job_type": {
"type": "string",
"enum": ["full-time", "part-time", "remote", "contract", "internship"],
"example": "full-time"
},
"description": { "type": "string", "example": "<p>Job details</p>" },
"mandatory_skills": {
"type": "array",
"items": { "type": "string" },
"example": ["Node.js", "Express"]
},
"good_to_have_skills": {
"type": "array",
"items": { "type": "string" },
"example": ["AWS"]
},
"responsibilities": {
"type": "array",
"items": { "type": "string" },
"example": ["Write code"]
},
"benefits": {
"type": "array",
"items": { "type": "string" },
"example": ["Health care"]
},
"status": {
"type": "string",
"enum": ["active", "closed", "draft"],
"example": "active"
}
}
},
"UserRequest": {
"type": "object",
"required": ["name", "email", "password"],
"properties": {
"name": { "type": "string", "example": "New Admin" },
"email": { "type": "string", "example": "[admin2@tekit.com](mailto:admin2@tekit.com)" },
"password": { "type": "string", "example": "Secure@123" },
"role": {
"type": "string",
"enum": ["super_admin", "admin"],
"example": "admin"
},
"permissions": {
"type": "object",
"properties": {
"blogs": {
"type": "object",
"properties": {
"view": { "type": "boolean" },
"create": { "type": "boolean" },
"edit": { "type": "boolean" },
"delete": { "type": "boolean" }
}
},
"jobs": {
"type": "object",
"properties": {
"view": { "type": "boolean" },
"create": { "type": "boolean" },
"edit": { "type": "boolean" },
"delete": { "type": "boolean" }
}
}
}
},
"status": {
"type": "string",
"enum": ["active", "inactive"],
"example": "active"
}
}
}
}
},
"security": [
{
"bearerAuth": []
}
],
"paths": {
"/admin/login": {
"post": {
"summary": "Admin Login",
"tags": ["Auth"],
"security": [],
"requestBody": {
"required": true,
"content": {
"application/json": {
"schema": { "$ref": "#/components/schemas/LoginRequest" }
}
}
},
"responses": {
"200": { "description": "Login successful" }
}
}
}
}
}
