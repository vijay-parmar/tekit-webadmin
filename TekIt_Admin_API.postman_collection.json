{
  "info": {
    "name": "TekIt Admin API",
    "description": "Complete Postman collection for TekIt Admin Panel REST API, including recent changes to Jobs and Blogs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"Prachi.agrawal@tekitsolution.com\",\n  \"password\": \"Admin@12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "login"
              ]
            }
          }
        },
        {
          "name": "Admin Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Get Profile (Me)",
